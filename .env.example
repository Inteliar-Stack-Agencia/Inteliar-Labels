# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# ── Supabase (required) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Analytics / Ads ───────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Tag de seguimiento de conversiones de Google Ads (formato AW-XXXXXXXXX).
# La cuenta 653-344-7092 (Etiquetar.app) usa AW-18333968448.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# ── Mercado Libre OAuth (integrations/mercadolibre) ─────────────────
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
# Site id for OAuth domain / marketplace. Defaults to Argentina if unset.
# See lib/mercadolibre.ts ML_SITE_DOMAINS for other countries (MLB, MLM, MCO, etc).
MERCADOLIBRE_SITE=MLA

# ── Tiendanube OAuth (integrations/tiendanube) ──────────────────────
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=

# ── Payments ──────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=
LICENSE_EMAIL_FROM=Inteliar Labels <licencias@etiquetar.app>

# ── AI (template chat assistant) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS=

# ── Cron ──────────────────────────────────────────────────────────────
# Shared secret Vercel Cron sends to authenticate scheduled jobs
CRON_SECRET=

# ── Cloud print relay (printer-agent only, not this Next.js app) ────
# See docs/RELAY.md. Only needed once cross-network Multipunto is enabled
# for a client; goes in the agent's agent-config.json, not here.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
