{
  "name": "inteliar-printer-agent",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Agente local de impresión multi-marca/multi-conexión - Inteliar Labels",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build:win": "pkg . --target node18-win-x64 --output dist/InteliarPrinterAgent.exe --compress GZip"
  },
  "pkg": {
    "assets": ["printers.json"],
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
