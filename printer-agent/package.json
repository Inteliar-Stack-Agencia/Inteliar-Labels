{
  "name": "inteliar-printer-agent",
  "version": "1.0.1",
  "private": true,
  "description": "Agente local de impresion - Inteliar Labels",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build:win": "pkg . --target node18-win-x64 --output dist/InteliarPrinterAgent.exe --compress GZip"
  },
  "pkg": {
    "assets": ["config.json"],
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
