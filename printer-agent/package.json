{
  "name": "inteliar-printer-agent",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Agente local de impresión multi-marca/multi-conexión - Inteliar Labels",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build:win": "pkg --target node20-win-x64 --output dist/InteliarPrinterAgent.exe ."
  },
  "pkg": {
    "scripts": ["src/**/*.js"],
    "targets": ["node20-win-x64"],
    "outputPath": "dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0"
  }
}
